# =========================================================================
# Korea-apt-index Project .gitignore
# Covers Frontend(Next.js), Backend(Python), OS, and IDE settings
# =========================================================================

# -------------------------------------------------------------------------
# OS System Files
# -------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -------------------------------------------------------------------------
# IDEs and Editors
# -------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# -------------------------------------------------------------------------
# Environments and Secrets
# -------------------------------------------------------------------------
.env
.env.*
!.env.example

# -------------------------------------------------------------------------
# Backend - Python
# -------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Jupyter Notebooks
.ipynb_checkpoints/

# Packaging
build/
dist/
*.egg-info/
wheels/

# Logs and DB
*.log
*.sqlite
*.sqlite3
*.db

# Data & Migrations (Optional)
# If your backend/data folder creates temporary processing files, they can be ignored
# backend/data/*
# !backend/data/.keep

# -------------------------------------------------------------------------
# Frontend - Node.js & Next.js
# -------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js
.next/
out/
.vercel
next-env.d.ts

# TypeScript
*.tsbuildinfo

# Testing
coverage/